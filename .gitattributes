* text=auto

# Source and config files should use LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-native script files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Do not normalize generated/vendor artifacts
Frontend/node_modules/** -text
Backend/node_modules/** -text
Frontend/dist/** -text
Backend/logs/** -text